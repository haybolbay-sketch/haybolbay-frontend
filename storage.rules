rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Customer identification storage
    match /customers/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Cleaner identification storage
    match /cleaners/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Allow admin to read overall for verification
    match /{allPaths=**} {
      allow read: if request.auth != null && (
        request.auth.token.email == 'jfresnidojr@gmail.com'
      );
    }
  }
}
